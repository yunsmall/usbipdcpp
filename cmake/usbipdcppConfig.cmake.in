@PACKAGE_INIT@


include("${CMAKE_CURRENT_LIST_DIR}/usbipdcppTargets.cmake")


include(CMakeFindDependencyMacro)

find_dependency(asio REQUIRED)
find_dependency(spdlog REQUIRED)

if (virtual_device IN_LIST usbipdcpp_FIND_COMPONENTS)
    if(TARGET usbipdcpp::usbipdcpp_virtual_device)
        add_library(usbipdcpp::virtual_device ALIAS usbipdcpp::usbipdcpp_virtual_device)
        set(usbipdcpp_virtual_device_FOUND TRUE)
    endif()
endif ()

if (libusb IN_LIST usbipdcpp_FIND_COMPONENTS)
    if(TARGET usbipdcpp::usbipdcpp_libusb)
        find_dependency(PkgConfig REQUIRED)
        pkg_check_modules(libusb REQUIRED IMPORTED_TARGET libusb-1.0)
        add_library(usbipdcpp::libusb ALIAS usbipdcpp::usbipdcpp_libusb)
        set(usbipdcpp_libusb_FOUND TRUE)
    endif()
endif ()

check_required_components(usbipdcpp)
